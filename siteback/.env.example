# ── siteback: переменные окружения ──
# Локально: скопируй в .env и заполни. На Railway задай в разделе Variables.

# Общая база (та же, что у бота). На Railway — ссылкой на Postgres.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Ключи ИИ (те же, что в боте): проверка работ (Anthropic) и распознавание фото (xAI/Grok).
# Имена ДОЛЖНЫ совпадать с тем, что читает код core/: ANTHROPIC_API_KEY и XAI_API_KEY.
ANTHROPIC_API_KEY=
XAI_API_KEY=

# Адрес(а) фронта на Vercel через запятую — кому разрешён вход с куками (CORS).
FRONT_ORIGINS=http://localhost:5173
# Куда вернуть пользователя после входа через Google/Telegram (обычно адрес фронта).
FRONT_REDIRECT_URL=http://localhost:5173
# Публичный адрес самого siteback (нужен для возвратов OAuth), без слэша в конце.
PUBLIC_BASE_URL=

# Секрет подписи куки-сессии — ОБЯЗАТЕЛЬНО свой длинный случайный в проде.
SESSION_SECRET=change-me-to-a-long-random-string
# Локально по http поставь COOKIE_SECURE=false и COOKIE_SAMESITE=lax.
COOKIE_SECURE=true
COOKIE_SAMESITE=none

# Режим оплаты: stub — заглушка (проверки начисляются сразу, без денег).
PAYMENTS_MODE=stub

# OAuth — заполни, когда будешь включать соответствующий вход (иначе он выключен).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
