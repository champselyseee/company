# ── botback: переменные окружения ──
# Локально: скопируй в .env и заполни. На Railway задай в разделе Variables службы бота.

# Токен бота от @BotFather.
TELEGRAM_TOKEN=

# Общая база (та же, что у сайта). На Railway — ссылкой на Postgres.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Ключ xAI/Grok — распознавание фото (core/grok.py) И проверка работ (core/grok_check.py).
# Имя ДОЛЖНО совпадать с тем, что читает код core/: XAI_API_KEY.
XAI_API_KEY=

# (необязательно) модель проверки работ; по умолчанию grok-4.
GROK_CHECK_MODEL=grok-4

# (необязательно) контакт поддержки для /help и заглушки оплаты.
SUPPORT_CONTACT=@champselyseee

# ── Мини-аппа (Telegram WebApp) ──
# Адрес мини-аппы (botfront на Vercel), напр. https://botupdatedront.vercel.app — для кнопки WebApp.
WEBAPP_URL=

# Порт веб-сервера бота (обслуживает мини-аппу). На Railway задаётся автоматически.
PORT=8080

# Разрешённый источник (CORS) для мини-аппы; '*' допустимо (вход по initData, куки не шлём).
WEBAPP_ALLOWED_ORIGIN=*
