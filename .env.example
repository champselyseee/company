# Строка подключения к Postgres.
# В Railway появляется автоматически как переменная DATABASE_URL (её брать оттуда).
# Локально для проверки скопируй этот файл в .env и подставь свою строку.
# Если подключаешься к Railway-базе снаружи, в конце может понадобиться ?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname
